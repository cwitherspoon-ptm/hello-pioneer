# Copy to .env and fill in the values from your Supabase project settings
# (Project Settings -> API). The anon/public key is safe for the browser.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (used by /api/share-note). Never shipped to the browser.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Optional verified sender; defaults to onboarding@resend.dev (test mode).
# RESEND_FROM=hello from Pioneer Species <notes@yourdomain.com>
